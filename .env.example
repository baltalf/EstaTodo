# SafeGuard AI — Environment Variables
# Copy this file to .env and fill in your values
# Backend (FastAPI) reads these via backend/core/config.py
# Frontend (Next.js) reads NEXT_PUBLIC_* vars from frontend/.env.local

# ─── Avalanche L1 ───────────────────────────────────────────────────────────
AVALANCHE_RPC_URL=http://127.0.0.1:9650/ext/bc/<your-chain-id>/rpc
AVALANCHE_CHAIN_ID=12345
AVALANCHE_PRIVATE_KEY=0x...your_private_key...
BLOCKCHAIN_ENABLED=false          # set to true if Avalanche node is running

# ─── IPFS — Pinata ──────────────────────────────────────────────────────────
# Crear cuenta gratuita en https://pinata.cloud
# Ir a: API Keys → Generate new key → JWT
# Sin este valor los clips quedan solo en storage local del camión.
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Genlayer ────────────────────────────────────────────────────────────────
# Simulador local de Genlayer (opcional; sin esto el veredicto es mock)
GENLAYER_SIMULATOR_URL=http://localhost:4000
GENLAYER_CONTRACT_ADDRESS=         # auto-cargado desde genlayer/deployed.json

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///C:/Users/BALTAZAR/safeguard/backend/safeguard.db

# ─── Frontend ────────────────────────────────────────────────────────────────
# Copiar en frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws/stream

# ─── Arweave (alternativa permanente a Pinata — implementación futura) ───────
# ARWEAVE_KEY=...
